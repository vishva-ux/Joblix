datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String
  name          String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  organizations UserOrganization[]
}

model Organization {
  id        String             @id @default(uuid())
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  users     UserOrganization[]
  projects  Project[]
}

model UserOrganization {
  userId         String
  organizationId String
  role           String // "ADMIN", "MEMBER"
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  apiKey         String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queues         Queue[]
}

model Queue {
  id               String            @id @default(uuid())
  projectId        String
  name             String
  priority         Int               @default(1)
  concurrencyLimit Int               @default(5)
  isPaused         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs             Job[]
  retryPolicies    RetryPolicy[]
  deadLetterQueue  DeadLetterQueue[]

  @@unique([projectId, name])
}

model RetryPolicy {
  id         String   @id @default(uuid())
  queueId    String   @unique
  strategy   String // "FIXED", "LINEAR", "EXPONENTIAL"
  maxRetries Int      @default(3)
  delayMs    Int      @default(1000)
  multiplier Float    @default(2.0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  queue      Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
}

model Job {
  id              String            @id @default(uuid())
  queueId         String
  status          String // "QUEUED", "SCHEDULED", "CLAIMED", "RUNNING", "COMPLETED", "FAILED"
  payload         String // JSON string
  result          String? // JSON/Text response from worker
  error           String? // Error detail if failed
  runAt           DateTime          @default(now())
  cronExpression  String? // For recurring cron jobs
  batchId         String? // Group ID for batching
  retryCount      Int               @default(0)
  maxRetries      Int               @default(3)
  claimedById     String?
  claimedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  queue           Queue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  claimedBy       Worker?           @relation("WorkerJobs", fields: [claimedById], references: [id], onDelete: SetNull)
  executions      JobExecution[]
  logs            JobLog[]
  deadLetterQueue DeadLetterQueue[]

  @@index([queueId, status, runAt])
  @@index([status])
}

model JobExecution {
  id         String    @id @default(uuid())
  jobId      String
  workerId   String
  status     String // "RUNNING", "COMPLETED", "FAILED"
  attempt    Int
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  error      String?
  durationMs Int?
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker     Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Worker {
  id            String            @id
  name          String
  status        String // "ACTIVE", "INACTIVE"
  lastHeartbeat DateTime          @default(now())
  concurrency   Int               @default(5)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  jobs          Job[]             @relation("WorkerJobs")
  executions    JobExecution[]
  heartbeats    WorkerHeartbeat[]
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String
  timestamp   DateTime @default(now())
  cpuUsage    Float
  memoryUsage Float
  activeJobs  Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, timestamp])
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String
  level     String // "INFO", "WARN", "ERROR"
  message   String
  timestamp DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model DeadLetterQueue {
  id       String   @id @default(uuid())
  jobId    String
  queueId  String
  failedAt DateTime @default(now())
  reason   String
  payload  String // JSON Snapshot
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  queue    Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
}
