{
  "name": "joblix-backend",
  "version": "1.0.0",
  "description": "Backend API Server and Worker service for Joblix Job Scheduler",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && prisma generate",
    "start:server": "tsx src/server.ts",
    "start:worker": "tsx src/worker.ts",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.12.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
